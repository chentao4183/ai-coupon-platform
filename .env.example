# Vercel KV Database Configuration
# Get these from your Vercel project dashboard: Storage > KV > Connect
KV_REST_API_URL=https://your-kv-instance.kv.vercel-storage.com
KV_REST_API_TOKEN=your-kv-rest-api-token-here

# Admin Authentication
# IMPORTANT: Use a strong password with at least 16 characters
# Generate a secure password: openssl rand -base64 24
ADMIN_PASSWORD=your-secure-admin-password-min-16-chars
